# =============================================================================
# OUTSOURCING SCORECARD — ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed or uploaded to the server.
# This file (.env.example) is safe to commit — it contains no real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# WORDPRESS SITE URL
# No trailing slash. The quiz POSTs to: {VITE_WP_URL}/wp-json/quiz/v1/submit
# -----------------------------------------------------------------------------

VITE_WP_URL = https://yoursite.com


# -----------------------------------------------------------------------------
# GOOGLE reCAPTCHA v3 — SITE KEY (public, safe to expose in frontend)
# Get keys at: https://www.google.com/recaptcha/admin/create
# Secret Key goes in quiz-endpoint.php — never here.
# -----------------------------------------------------------------------------

VITE_RECAPTCHA_SITE_KEY = your-recaptcha-v3-site-key
